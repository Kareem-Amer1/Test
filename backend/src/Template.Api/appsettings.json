{
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:8080", "http://localhost:5173" ]
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DefaultDatabaseKey": "Default",
    "Databases": {
      "Default": "voiceflow_studio"
    }
  },
  "Jwt": {
    "Issuer": "voiceflow-studio",
    "Audience": "voiceflow-studio",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30,
    "PrivateKeyPem": "-----BEGIN PRIVATE KEY-----\\n-----END PRIVATE KEY-----",
    "PublicKeyPem": "-----BEGIN PUBLIC KEY-----\\n-----END PUBLIC KEY-----"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  }
}
